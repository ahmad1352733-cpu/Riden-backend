{
  "expo": {
    "name": "RIDEN",
    "slug": "riden-passenger-app",
    "owner": "farah_hammad",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "riden-passenger-app",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ddb45a5b-2f33-415c-9467-ff89c70c196a",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1B2D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "jo.riden.passenger"
    },
    "android": {
      "package": "jo.riden.passenger",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0F1B2D"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "يحتاج RIDEN إلى الوصول للموقع لتتبع رحلتك.",
          "locationWhenInUsePermission": "يحتاج RIDEN إلى موقعك لإيجاد كابتن قريب منك."
        }
      ],
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "ddb45a5b-2f33-415c-9467-ff89c70c196a"
      }
    }
  }
}
