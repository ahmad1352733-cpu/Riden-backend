{
  "expo": {
    "name": "RIDEN - Captain",
    "slug": "riden-captain-app",
    "owner": "farah_hammad",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "riden-captain-app",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c31c7e21-67aa-4b65-a241-0bdb7e6b7bbc",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1B2D"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "يحتاج RIDEN إلى موقعك لتحديد مكانك وإرساله للركاب خلال العمل",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "يستخدم RIDEN موقعك لمشاركته مع الركاب خلال الرحلات"
      }
    },
    "android": {
      "package": "jo.riden.captain",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0F1B2D"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "يحتاج RIDEN إلى موقعك لمشاركته مع الركاب",
          "locationAlwaysAndWhenInUsePermission": "يستخدم RIDEN موقعك خلال الرحلات"
        }
      ],
      "expo-updates",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#22C55E",
          "defaultChannel": "general",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "c31c7e21-67aa-4b65-a241-0bdb7e6b7bbc"
      }
    }
  }
}
